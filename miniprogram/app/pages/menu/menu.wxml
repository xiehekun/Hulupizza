<view class="menu-page">
  <scroll-view class="category-bar" scroll-x>
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category {{activeCategory === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectCategory"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <view class="menu-list">
    <view class="product panel" wx:for="{{visibleProducts}}" wx:key="id">
      <view class="photo">{{item.initial}}</view>
      <view class="product-main">
        <view class="between">
          <view class="product-name">{{item.name}}</view>
          <view wx:if="{{item.tags.length}}" class="tag">{{item.tags[0]}}</view>
        </view>
        <view class="desc">{{item.description}}</view>
        <view class="between">
          <view class="price">￥{{item.price}}</view>
          <button
            class="add-btn"
            disabled="{{item.soldOut}}"
            data-id="{{item.id}}"
            bindtap="openProduct"
          >
            {{item.soldOut ? '售罄' : '选购'}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="cart-bar" wx:if="{{cartCount > 0}}">
    <view>
      <view>已选 {{cartCount}} 件</view>
      <view class="cart-total">合计 ￥{{cartTotal}}</view>
    </view>
    <button class="checkout-btn" bindtap="goCart">去结算</button>
  </view>

  <view class="sheet-mask" wx:if="{{selectedProduct}}" bindtap="closeProduct"></view>
  <view class="option-sheet" wx:if="{{selectedProduct}}">
    <view class="sheet-title">{{selectedProduct.name}}</view>
    <view class="muted sheet-desc">{{selectedProduct.description}}</view>

    <view wx:for="{{selectedProduct.options}}" wx:key="group" class="option-group">
      <view class="option-title">{{item.group}}</view>
      <view class="option-values">
        <view
          wx:for="{{item.values}}"
          wx:for-item="option"
          wx:key="name"
          class="option {{option.selected ? 'selected' : ''}}"
          data-group="{{item.group}}"
          data-name="{{option.name}}"
          data-price="{{option.price}}"
          bindtap="selectOption"
        >
          {{option.name}}{{option.price ? ' +￥' + option.price : ''}}
        </view>
      </view>
    </view>

    <view class="between sheet-footer">
      <view class="price">￥{{selectedPrice}}</view>
      <button class="primary-btn sheet-btn" bindtap="addToCart">加入购物车</button>
    </view>
  </view>
</view>
