.menu-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.category-bar {
  white-space: nowrap;
  padding: 20rpx 24rpx 12rpx;
  background: #f7f4ef;
  position: sticky;
  top: 0;
  z-index: 2;
}

.category {
  display: inline-flex;
  height: 64rpx;
  align-items: center;
  padding: 0 24rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #555555;
  border: 1rpx solid #ece5dc;
}

.category.active {
  background: #222222;
  color: #ffffff;
  border-color: #222222;
}

.menu-list {
  padding: 12rpx 24rpx;
}

.product {
  display: flex;
  gap: 20rpx;
}

.photo {
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  background: #2b2b2b;
  color: #f2c7a1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  flex: none;
}

.product-main {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 800;
}

.desc {
  color: #777777;
  font-size: 24rpx;
  line-height: 1.5;
  min-height: 72rpx;
  margin: 10rpx 0;
}

.tag {
  background: #f7e3d6;
  color: #9c2f19;
  border-radius: 6rpx;
  padding: 4rpx 10rpx;
  font-size: 22rpx;
}

.add-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 8rpx;
  background: #b23a1f;
  color: #ffffff;
  font-size: 24rpx;
  margin: 0;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: #222222;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 3;
}

.cart-total {
  color: #f2c7a1;
  font-weight: 700;
  margin-top: 4rpx;
}

.checkout-btn {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #222222;
  font-size: 26rpx;
  font-weight: 700;
  margin: 0;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 10;
}

.option-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 8rpx 8rpx 0 0;
  padding: 28rpx;
  z-index: 11;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-desc {
  margin-top: 8rpx;
  line-height: 1.5;
}

.option-group {
  margin-top: 24rpx;
}

.option-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

.option-values {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option {
  border: 1rpx solid #e2d9cf;
  border-radius: 8rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
}

.option.selected {
  border-color: #b23a1f;
  color: #b23a1f;
  background: #fff3ec;
}

.sheet-footer {
  margin-top: 32rpx;
}

.sheet-btn {
  width: 260rpx;
  margin: 0;
}
