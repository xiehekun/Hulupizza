<view class="page">
  <view class="coupon panel" wx:for="{{coupons}}" wx:key="id">
    <view>
      <view class="coupon-name">{{item.name}}</view>
      <view class="muted">{{item.description}}</view>
    </view>
    <button
      class="{{item.received ? 'ghost-btn' : 'secondary-btn'}} coupon-btn"
      data-id="{{item.id}}"
      bindtap="receiveCoupon"
    >
      {{item.received ? '已领取' : '领取'}}
    </button>
  </view>
</view>
