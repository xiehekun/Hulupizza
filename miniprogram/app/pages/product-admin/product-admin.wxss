.admin-page {
  padding-bottom: 48rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.add-button {
  width: 128rpx;
  margin: 0;
}

.form-panel {
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  color: #777777;
  margin-bottom: 8rpx;
}

.strong {
  color: #222222;
  font-weight: 700;
}

input,
textarea,
.picker-value {
  width: 100%;
  background: #f7f4ef;
  border-radius: 8rpx;
}

input,
.picker-value {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 18rpx;
}

textarea {
  min-height: 140rpx;
  line-height: 1.5;
  padding: 18rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0ebe4;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.save-btn {
  margin: 0;
}

.product-card {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0ebe4;
}

.product-card:last-child {
  border-bottom: 0;
}

.product-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.state {
  height: 44rpx;
  min-width: 88rpx;
  border-radius: 6rpx;
  background: #eeeeee;
  color: #777777;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex: none;
}

.state.online {
  background: #e8f4ed;
  color: #207a45;
}

.desc {
  color: #777777;
  line-height: 1.5;
  margin-top: 12rpx;
}

.tag-row {
  margin-top: 12rpx;
}

.tag {
  display: inline-flex;
  border-radius: 6rpx;
  background: #f7e3d6;
  color: #9c2f19;
  padding: 6rpx 12rpx;
  font-size: 22rpx;
}

.actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.action-btn,
.danger-btn {
  width: 100%;
  margin: 0;
  font-size: 24rpx;
}

.danger-btn {
  color: #b23a1f;
}
