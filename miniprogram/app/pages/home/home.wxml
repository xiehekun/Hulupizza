<view class="page">
  <view class="hero">
    <view>
      <view class="store-name">{{store.name}}</view>
      <view class="store-status">{{store.status}} · 今日可堂食 / 自取</view>
    </view>
    <view class="flame">PIZZA</view>
  </view>

  <view class="quick-grid section">
    <view class="quick-card">
      <text class="quick-title">堂食点餐</text>
      <input class="table-input" value="{{tableNo}}" placeholder="桌号，例如 A01" bindinput="onTableInput" />
      <button class="secondary-btn quick-button" bindtap="startDineIn">开始</button>
    </view>
    <button class="quick-card" bindtap="startPickup">
      <text class="quick-title">到店自取</text>
      <text class="quick-sub">提前下单，到店取餐</text>
    </button>
  </view>

  <view class="panel section">
    <view class="between">
      <view>
        <view class="section-title">今日优惠</view>
        <view class="muted">新客券、满减券可领取</view>
      </view>
      <button class="ghost-btn small-btn" bindtap="goCoupons">领取</button>
    </view>
  </view>

  <view class="panel section">
    <view class="section-title">招牌推荐</view>
    <view class="recommend">
      <view class="recommend-item" wx:for="{{recommends}}" wx:key="id">
        <view>
          <view class="product-name">{{item.name}}</view>
          <view class="muted">{{item.description}}</view>
        </view>
        <view class="price">￥{{item.price}}</view>
      </view>
    </view>
    <button class="primary-btn" bindtap="goMenu">开始点餐</button>
  </view>
</view>
