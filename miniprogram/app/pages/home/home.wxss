.hero {
  min-height: 260rpx;
  background: #171717;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.store-name {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.store-status {
  color: #f2c7a1;
  font-size: 26rpx;
}

.flame {
  color: #f2c7a1;
  border: 1rpx solid #7d5a45;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  letter-spacing: 0;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  background: #ffffff;
  border: 1rpx solid #ece5dc;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: left;
  line-height: 1.4;
}

.table-input {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 16rpx;
  margin-top: 4rpx;
  border-radius: 8rpx;
  background: #f7f4ef;
  font-size: 24rpx;
}

.quick-button {
  width: 100%;
  height: 56rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
}

.quick-title {
  display: block;
  color: #222222;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.quick-sub {
  display: block;
  color: #777777;
  font-size: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.small-btn {
  width: 132rpx;
  margin: 0;
}

.recommend-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0ebe4;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.recommend-item:last-child {
  border-bottom: 0;
}

.product-name {
  font-weight: 700;
  margin-bottom: 8rpx;
}
