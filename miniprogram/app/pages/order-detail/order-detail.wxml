<view class="page" wx:if="{{order}}">
  <view class="panel section">
    <view class="status">{{order.status}}</view>
    <view class="muted">订单号 {{order.id}}</view>
    <view class="info">{{order.diningTypeText}}</view>
    <view wx:if="{{order.diningType === 'pickup'}}" class="pickup-code">取餐码 {{order.pickupCode}}</view>
  </view>

  <view class="panel section">
    <view class="section-title">菜品明细</view>
    <view class="order-item" wx:for="{{order.items}}" wx:key="key">
      <view>
        <view class="item-name">{{item.name}} x {{item.quantity}}</view>
        <view class="muted">{{item.optionText}}</view>
      </view>
      <view>￥{{item.lineTotal}}</view>
    </view>
  </view>

  <view class="panel section">
    <view class="between line">
      <text>商品金额</text>
      <text>￥{{order.totalAmount}}</text>
    </view>
    <view class="between line">
      <text>优惠金额</text>
      <text>-￥{{order.discountAmount}}</text>
    </view>
    <view class="between payable">
      <text>实付</text>
      <text>￥{{order.payableAmount}}</text>
    </view>
  </view>

  <button class="secondary-btn" bindtap="completeOrder">模拟出餐完成</button>
</view>
