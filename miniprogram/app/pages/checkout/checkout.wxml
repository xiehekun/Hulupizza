<view class="page">
  <view class="panel section">
    <view class="section-title">就餐方式</view>
    <view class="mode-row">
      <view class="mode {{diningType === 'dine-in' ? 'active' : ''}}" data-type="dine-in" bindtap="selectDiningType">堂食</view>
      <view class="mode {{diningType === 'pickup' ? 'active' : ''}}" data-type="pickup" bindtap="selectDiningType">自取</view>
    </view>

    <view wx:if="{{diningType === 'dine-in'}}" class="field">
      <view class="label">桌号</view>
      <input value="{{tableNo}}" placeholder="例如 A01" bindinput="onTableInput" />
    </view>

    <view wx:if="{{diningType === 'pickup'}}" class="field">
      <view class="label">取餐时间</view>
      <input value="{{pickupTime}}" placeholder="例如 18:30" bindinput="onPickupInput" />
    </view>
  </view>

  <view class="panel section">
    <view class="section-title">商品</view>
    <view class="order-item" wx:for="{{cart}}" wx:key="key">
      <view>
        <view class="item-name">{{item.name}} x {{item.quantity}}</view>
        <view class="muted">{{item.optionText}}</view>
      </view>
      <view>￥{{item.lineTotal}}</view>
    </view>
  </view>

  <view class="panel section">
    <view class="section-title">优惠</view>
    <view wx:if="{{availableCoupons.length === 0}}" class="muted">暂无可用优惠券</view>
    <view
      wx:for="{{availableCoupons}}"
      wx:key="id"
      class="coupon-row {{selectedCouponId === item.id ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectCoupon"
    >
      <view>
        <view class="item-name">{{item.name}}</view>
        <view class="muted">{{item.description}}</view>
      </view>
      <view class="price">-￥{{item.amount}}</view>
    </view>
  </view>

  <view class="panel section">
    <view class="section-title">备注</view>
    <textarea placeholder="口味、忌口或其他说明" value="{{remark}}" bindinput="onRemarkInput"></textarea>
  </view>

  <view class="panel pay-panel">
    <view class="between line">
      <text>商品金额</text>
      <text>￥{{cartTotal}}</text>
    </view>
    <view class="between line">
      <text>优惠金额</text>
      <text>-￥{{discountAmount}}</text>
    </view>
    <view class="between payable">
      <text>实付</text>
      <text>￥{{payableAmount}}</text>
    </view>
    <button class="primary-btn" bindtap="submitOrder">模拟支付并下单</button>
  </view>
</view>
